{
    "name": "lutze/sorted-linked-list",
    "description": "A type-safe sorted linked list for PHP",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "SortedLinkedList\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SortedLinkedList\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.1"
    }
}
